# Browser details
[browser]
home_url: http://www.example.com
kiosk: False
user_agent: ""
restrict_domain: False
restricted_domain_regex: .*example.com.*
zabbix: True
zabbix_agentd_cfg: /etc/zabbix/zabbix_agentd.conf
zabbix_hostname: example-machine
